NODE_ENV=development
PORT=3000
STRIPE_API_URL=https://api.stripe.com/v1
LOG_LEVEL=debug
# How long an Idempotency-Key + its stored response are retained (seconds).
IDEMPOTENCY_TTL_SECONDS=86400
# Token-bucket rate limiter: burst size and sustained refill rate (tokens/sec).
RATE_LIMIT_CAPACITY=20
RATE_LIMIT_REFILL_PER_SECOND=10
# Payment gateway resilience: per-attempt timeout, bounded retries with backoff,
# and the circuit-breaker timeout that bounds the whole retried operation.
GATEWAY_TIMEOUT_MS=2000
GATEWAY_MAX_RETRIES=2
GATEWAY_RETRY_BASE_MS=100
GATEWAY_BREAKER_TIMEOUT_MS=8000
# When set, idempotency + rate limiting use distributed Redis stores; otherwise
# they fall back to in-memory (single-instance). Start one with `docker compose up -d redis`.
# REDIS_URL=redis://localhost:6379
