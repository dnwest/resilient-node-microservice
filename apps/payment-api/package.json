{
  "name": "payment-api",
  "version": "1.0.0",
  "private": true,
  "description": "Resilient Payment Microservice with Circuit Breaker and Observability",
  "scripts": {
    "dev": "tsx watch src/infrastructure/http/server.ts",
    "build": "tsc",
    "start": "node dist/infrastructure/http/server.js",
